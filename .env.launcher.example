# Phaser Launcher playtest defaults
# Copy this file to .env.launcher.local only if you need to override the defaults
# used by `npm run launcher:prepare`.

# The Launcher bundle defaults both flags to true so playtest-only controls and
# console diagnostics are available even though the bundle is not served by Vite.
VITE_ENABLE_DEV_MENU=true
VITE_DEBUG_LOGS=true
