# Rivalis multiplayer WebSocket endpoint. Must be ws:// or wss://.
VITE_RIVALIS_WS_URL=wss://your-rivalis-server.example/ws

# Client auth ticket passed to Rivalis. Prefer short-lived/public-safe tickets.
VITE_RIVALIS_TICKET=your-rivalis-ticket

# Use "protocol" when the Rivalis server is configured to accept tickets via
# Sec-WebSocket-Protocol. Use "query" only for local/back-compat servers.
VITE_RIVALIS_TICKET_SOURCE=protocol

# Number of reconnect attempts before surfacing a terminal failure.
VITE_RIVALIS_RECONNECT_MAX=4
