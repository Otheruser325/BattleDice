# Battle Dice local dev defaults
# Copy this file to .env.local for Vite, then edit values as needed.

# Shows the in-game DEV BUILD MENU tab. Vite dev builds default to true when unset,
# but keeping this explicit makes local playtest setups easier to compare.
VITE_ENABLE_DEV_MENU=true

# Prints Battle Dice debug logs to the browser console and keeps the global
# window.__battleDiceDebug helpers available for dump/latest inspection.
VITE_DEBUG_LOGS=true
