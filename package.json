{
  "name": "battle-dice-autoroller",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:launcher": "npm run launcher:prepare && vite",
    "build": "tsc --noEmit && npm run launcher:prepare && vite build && npm run launcher:clean",
    "preview": "vite preview",
    "launcher:prepare": "npm run bundle:playtest && npm run copy:playtest-assets",
    "launcher:clean": "node scripts/clean-playtest-assets.mjs",
    "bundle:playtest": "node scripts/build-playtest-bundle.mjs",
    "copy:playtest-assets": "node scripts/sync-playtest-assets.mjs",
    "clean:playtest-assets": "npm run launcher:clean",
    "dev:clean": "npm run launcher:clean"
  },
  "dependencies": {
    "@rivalis/browser": "^6.0.0",
    "@toolcase/base": "^2.0.0",
    "@toolcase/logging": "^2.0.0",
    "@toolcase/serializer": "^2.0.2",
    "phaser": "^3.90.0",
    "process": "^0.11.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.27.7",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vite-plugin-node-polyfills": "^0.28.0",
    "webpack": "^5.x",
    "webpack-cli": "^5.x"
  }
}
