  "rarity": "Mythic",
  "skills": [
    {
      "type": "Passive",
      "title": "Furious Claw",
      "description": "Enemy dice 2 tiles closer to Leon will be attacked doubly, with a 20% chance to cause critical damage.",
      "modifiers": {
        "notes": [
          "runtime:leonFuriousClaw"
        ]
      }
    },
    {
      "type": "Passive",
      "title": "Mighty Roar",
      "description": "If no dice are in range, charges to the nearest enemy die and immediately executes Furious Claw, stunning its target for 2 turns.",
      "modifiers": {
        "statusEffect": "stun",
        "durationTurns": 2,
        "notes": [
          "runtime:leonMightyRoar"
        ]
      }
    },
    {
      "type": "OnKill",
      "title": "Rage Or Nothing",
      "description": "Leon gains +20% basic attack damage for each fallen foe.",
      "modifiers": {
        "targetMaxHpBonusRate": 0.2,
        "notes": [
          "runtime:leonRage",
          "runtime:unlockAtClass6"
        ]
      }
    }
  ],
  "accent": "#ffbf4a",
  "targetingMode": "Nearest",
  "isBoss": true
